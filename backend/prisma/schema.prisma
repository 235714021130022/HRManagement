generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GenderEmployee {
  Male
  Femail
}

model Role {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name_role String @db.Char(100)
  is_active Boolean @default(true)
  employees EmployeeRole[]
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model Employee {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_name String? @db.Char(300)
  password String @db.Char(100)
  date_of_birth DateTime? @db.Date
  gender GenderEmployee?
  address String? @db.Text
  email String? @db.Char(100)
  work_unit String? //khoa ngoai
  position String? // khoa ngoai
  job_title String? @db.Char(50)
  director_id String? @db.Uuid
  director Employee? @relation("EmployeeTree", fields: [director_id], references: [id], onDelete: SetNull)
  subor_staff Employee[] @relation("EmployeeTree")
  status String @db.Char(50) // dang lam viec;...
  first_day_of_work DateTime? @db.Date
  official_date DateTime? @db.Date
  phone_unit String? @db.Char(15)
  email_unit String? @db.Char(100)
  email_account String? @db.Char(100) @unique
  phone_account String? @db.Char(15) @unique
  is_active Boolean @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  roles EmployeeRole[]
}

model EmployeeRole {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  id_role     String @db.Uuid
  id_employee String @db.Uuid

  role     Role     @relation(fields: [id_role], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Employee @relation(fields: [id_employee], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_role, id_employee])
  @@index([id_role])
  @@index([id_employee])
}

model InforCompany {
  id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name String @db.Char(255)
  acronym_name String @db.Char(50)
  business_type String @db.Char(100)
  tax_idennumber String @db.Char(13)
  code_company String @db.Char(10)
  date_stablish DateTime @db.Date
  image_logo String @db.Text
  code_business String @db.Char(50)
  date_of_issue DateTime @db.Date
  place_of_issue String @db.Text
  unit_title String @db.Char(255)
  address String @db.Text
  phone_number String @db.Char(15)
  fax String @db.Char(255)
  email String @db.Char(255)
  website String @db.Char(255)  
  status String @db.Char(100) // dang theo doi; ngung theo doi
  parent_id String? @db.Uuid
  parent InforCompany? @relation("CompanyTree", fields: [parent_id], references: [id], onDelete: SetNull)
  childrent InforCompany[] @relation("CompanyTree")
  organization_level String @db.Char(255)
  number_arrange Int @db.Integer
  field_of_activity String @db.Char(50) 
  @@index([parent_id])
}