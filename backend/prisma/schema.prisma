// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

//pnpm prisma generate --schema prisma/schema.prisma && pnpm prisma migrate status --schema prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum GenderEmployee {
  Male
  Female
}
//#region VAI TRO - MD
model Role {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_code String? @db.VarChar(50) @unique
  name_role String? @db.VarChar(100)
  is_active Boolean @default(true)
  status String @db.VarChar(50)
  employees EmployeeRole[]
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

//#region NHAN VIEN - MD
model Employee {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid // 🔑 Khóa chính UUID, tự sinh bằng gen_random_uuid()
  emp_code String? @db.VarChar(50) @unique // 🏷️ Mã nhân viên Internal, duy nhất, có thể null (auto generate)
  employee_name String? @db.VarChar(300) // 👤 Tên đầy đủ nhân viên
  password String @db.VarChar(100) // 🔐 Mật khẩu đăng nhập (đã hash)
  date_of_birth DateTime? @db.Date // 🎂 Ngày sinh (chỉ lưu ngày, không lưu giờ)
  gender GenderEmployee? // 🚻 Giới tính (enum GenderEmployee)
  address String? @db.Text // 🏠 Địa chỉ cư trú
  email String? @db.VarChar(100) // 📧 Email cá nhân
  status String @db.VarChar(50) // 📊 Trạng thái làm việc (Active, Inactive, Nghỉ việc...)
  email_account String @db.VarChar(100) @unique // 🔑 Email dùng để đăng nhập hệ thống (duy nhất)
  phone_account String @db.VarChar(15) @unique // 📱 Số điện thoại dùng để đăng nhập (duy nhất)
  is_active Boolean @default(true) // ✅ Trạng thái hoạt động (soft delete / bật tắt tài khoản)
  created_at DateTime @default(now()) @db.Timestamp(6) // ⏱ Thời gian tạo bản ghi
  updated_at DateTime @default(now()) @db.Timestamp(6) // 🔄 Thời gian cập nhật gần nhất
  roles EmployeeRole[] // 🛡 Quan hệ nhiều-nhiều với Role thông qua bảng EmployeeRole
  contactPersonInRecruitment Recruitment_Infor[] // 📌 Là người liên hệ trong các đợt tuyển dụng
  referrerOfCandidates Candidate[] // 🎯 Là người giới thiệu ứng viên
  jobApplications Job[] // 📋 Các công việc được giao cho nhân viên
  registerCompany CompanyRegistrationRequest[] // 🏢 Các yêu cầu đăng ký công ty do nhân viên tạo
  reviewCandidate CandidateReview[]
  candidateAuditLogs CandidateAuditLog[]
}

//#region NHAN VIEN VAI TRO -NMD
model EmployeeRole {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_role     String @db.Uuid
  id_employee String @db.Uuid
  role     Role     @relation(fields: [id_role], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Employee @relation(fields: [id_employee], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_role, id_employee])
  @@index([id_role])
  @@index([id_employee])
}

//#region THONG TIN CONG TY - MD
model InforCompany {
  id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid // PK UUID công ty

  infor_code String? @db.VarChar(50) @unique // Mã Internal công ty (unique)
  full_name String? @db.VarChar(255) // Tên đầy đủ công ty
  acronym_name String? @db.VarChar(50) // Tên viết tắt

  business_type String? @db.VarChar(100) // Loại hình DN (TNHH/Cổ phần/...)
  tax_idennumber String? @db.VarChar(13) // Mã số thuế
  code_company String? @db.VarChar(10) // Mã đăng ký doanh nghiệp

  date_stablish DateTime? @db.Date // Ngày thành lập
  image_logo String? @db.Text // Logo (URL/base64)

  code_business String? @db.VarChar(50) // Số GPKD / giấy phép kinh doanh
  date_of_issue DateTime? @db.Date // Ngày cấp GPKD
  place_of_issue String? @db.Text // Nơi cấp GPKD

  address String? @db.Text // Địa chỉ
  phone_number String? @db.VarChar(15) // SĐT liên hệ
  fax String? @db.VarChar(255) // Fax
  email String? @db.VarChar(255) // Email liên hệ
  website String? @db.VarChar(255) // Website

  status String? @db.VarChar(100) // Trạng thái theo dõi (đang/ ngừng)
  field_of_activity String? @db.VarChar(50) // Lĩnh vực hoạt động (IT/Banking/...)

  is_active Boolean @default(true) // Còn hoạt động trong hệ thống

  created_at DateTime @default(now()) @db.Timestamp(6) // Thời điểm tạo
  updated_at DateTime @default(now()) @db.Timestamp(6) // Thời điểm cập nhật

  rankUnits Rank[] // Danh sách Rank thuộc công ty
  department Recruitment_Infor[] @relation("DepartmentCompany") // Tuyển dụng theo phòng ban (FK về company)
  positionPosts Setting_Position_Posts[] // Danh sách vị trí đăng tuyển thuộc công ty
  registrationRequest CompanyRegistrationRequest[] // Yêu cầu đăng ký sử dụng hệ thống của công ty
  workLocations Recruitment_Infor[] @relation("WorkLocationCompany") // Tuyển dụng theo địa điểm làm việc (FK về company)
  settingEmail SettingEmail[] // Cấu hình email của công ty
}

//#region THONG TIN UNG TUYEN - MD
model Recruitment_Infor {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recruitment_code String? @db.VarChar(50) @unique
  internal_title String? @db.VarChar(300)
  post_title String? @db.VarChar(300)

  department_id String? @db.Uuid
  work_location_id String? @db.Uuid
  rank_id String? @db.Uuid
  contact_person_id String? @db.Uuid

  type_of_job String? @db.VarChar(150)
  application_deadline DateTime? @db.Date
  salary_from Float? @db.DoublePrecision
  salary_to Float? @db.DoublePrecision
  salary_currency String? @db.VarChar(50)
  status String? @db.VarChar(50)

  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  department   InforCompany? @relation("DepartmentCompany", fields: [department_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workLocation InforCompany? @relation("WorkLocationCompany", fields: [work_location_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  rank Rank? @relation(fields: [rank_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contactPerson Employee? @relation(fields: [contact_person_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  position_post_id String @db.Uuid
  positionPost Setting_Position_Posts @relation(fields: [position_post_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  recruitmentPlans Recruitment_Plan_Parent[]
  recruitmentCosts Recruitment_Costs[]
  statusApplication Application[]
  
}
// ===================
//#region KE HOACH UNG TUYEN - CHA  - HAVED
model Recruitment_Plan_Parent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recruitment_id String? @db.Uuid // khoa ngoai
  total_real_number Int? @db.Integer
  monthly_target DateTime? @db.Date
  expected_deadline DateTime? @db.Date
  recruitmentInfor Recruitment_Infor? @relation(fields: [recruitment_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recruitmentPlanChildBatches Recruitment_Plan_Child_Batches[]
  recruitmentPlanChildPosteds Recruitment_Plan_Child_Posted[]
}

//#region KE HOACH THEO DOT  - HAVED
model Recruitment_Plan_Child_Batches {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recruitment_plan_parent_id String? @db.Uuid // khoa ngoai
  batches_title String? @db.VarChar(200) @unique
  from_date DateTime? @db.Date
  to_date DateTime? @db.Date
  number_recruitment Int? @db.Integer
  monthly_target DateTime? @db.Date
  recruitmentPlanParent Recruitment_Plan_Parent? @relation(fields: [recruitment_plan_parent_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

//#region KE HOACH THEO TIN - HAVED
model Recruitment_Plan_Child_Posted {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recruitment_plan_parent_id String? @db.Uuid // khoa ngoai
  posted_date DateTime? @db.Date
  expiration_date DateTime? @db.Date
  job_board String? @db.VarChar(100)
  recruitmentPlanParent Recruitment_Plan_Parent? @relation(fields: [recruitment_plan_parent_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

//#region CHI PHI TIN TUYEN KHÁC - HAVED
model Recruitment_Costs{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recruitment_id String? @db.Uuid // khoa ngoai
  cost_type String? @db.VarChar(300)
  amount Float? @db.DoublePrecision
  currency String? @db.VarChar(50)
  recruitmentInfor Recruitment_Infor? @relation(fields: [recruitment_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

// =============================================== SETTING MODELS ==================================================
//#region VI TRI UNG VIEN - MD
model Setting_Position_Posts{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  position_code String? @db.VarChar(50) @unique
  name_post String? @db.VarChar(100)
  unit_id String? @db.Uuid
  description_post String? @db.Text
  requirements_post String? @db.Text
  benefits_post String? @db.Text
  Setting_Process_Recruitment_id String? @db.Uuid
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  auto_rotation Boolean @default(false)
  auto_eli_candidate Boolean @default(false)
  auto_near Boolean @default(false)
  status String? @db.VarChar(50) 
  inforCompany InforCompany? @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  positionSkill PositionSkill[]
  recInfor Recruitment_Infor[]
}

//#region CAP BAC - MD
model Rank {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rank_code String? @db.VarChar(50) @unique
  name_rank String? @db.VarChar(100)
  unit_id String? @db.Uuid
  status String? @db.VarChar(50)
  rankUnit InforCompany? @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  description String? @db.Text
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  rank_levels Recruitment_Infor[]
}
 
 //#region TRINH DO DAO TAO - MD
model Setting_Training_Level {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_code String? @db.VarChar(50) @unique
  name_level String? @db.VarChar(100)
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

//#region  UNG VIEN TIEM NANG - MD
model Setting_Potential_Type {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String
  description String?
  is_active Boolean @default(true)
  candidate Candidate[]
}

//#region EMAIL
model SettingEmail {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sec_code     String?   @db.VarChar(50) @unique
  name         String?   @db.VarChar(300) // email_name hoặc offer_name
  unit_id      String?   @db.Uuid
  subject      String?   @db.VarChar(255) // email_subject hoặc offer_subject
  body         String?   @db.Text         // email_body hoặc offer_body
  auto_send    Boolean?  @default(false)  // chỉ dùng cho 'other', job_offer có thể null
  is_active    Boolean   @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  inforCompany InforCompany? @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
//#region UNG VIEN - MD
model Candidate {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid // ❌ Khóa chính UUID, dùng để view/edit/delete, không show table
  candidate_code String? @db.VarChar(50) @unique                    // 🟡 Mã ứng viên (unique) - nên gộp hiển thị dưới tên ở table
  candidate_name String? @db.VarChar(300)                           // ✅ Tên ứng viên - cột quan trọng nhất trên table
  
  date_of_birth DateTime? @db.Date                                  // ❌ Ngày sinh - để detail/form, không cần ở list
  gender String? @db.VarChar(50)                                    // ❌ Giới tính - để detail/form, list không cần

  phone_number String? @db.VarChar(15)                              // ✅ SĐT - nên hiển thị (liên hệ nhanh)
  email String? @db.VarChar(100)                                    // ✅ Email - nên hiển thị (liên hệ nhanh)

  address String? @db.Text                                          // ❌ Địa chỉ chi tiết - dài, để detail
  country String? @db.VarChar(100)                                  // ❌ Quốc gia - thường để detail
  provice String? @db.VarChar(100)                                  // ❌ Tỉnh/Thành (đang bị typo provice) - để detail
  district String? @db.VarChar(100)                                 // ❌ Quận/Huyện - để detail

  date_applied DateTime? @db.Date                                   // ✅ Ngày apply - nên hiển thị để biết mới/cũ

  referrer_id String? @db.Uuid                                      // ❌ FK người giới thiệu (id) - không show id, chỉ show referrer name nếu join


  referrer Employee? @relation(                                     fields: [referrer_id], references: [id],onDelete: SetNull, onUpdate: Cascade ) // 🟡 Quan hệ tới nhân viên giới thiệu - table có thể show tên referrer (nếu quy trình cần)


  is_active Boolean @default(true)                                   // ✅ Trạng thái active/inactive - nên show badge trên table
  is_potential Boolean @default(false)                               // 🟡 Đánh dấu tiềm năng - thường show icon/tag nhỏ hoặc để filter, không bắt buộc cột riêng

  potential_type_id String? @db.Uuid                                 // ❌ FK loại tiềm năng (id) - không show id, chỉ show type name nếu join
  potential Setting_Potential_Type? @relation(                       fields: [potential_type_id], references: [id], onDelete: Cascade, onUpdate: Cascade ) // 🟡 Quan hệ loại tiềm năng - nếu dùng, show tên loại ở detail/
  cv_file           String?  @db.VarChar(500)
  cv_uploaded_at    DateTime?
  avatar_file       String?  @db.VarChar(500)
  avatar_uploaded_at DateTime?
  created_at DateTime? @default(now()) @db.Timestamp(6)              // ❌ Ngày tạo - thường không cần ở list (chỉ cần nếu audit)
  updated_at DateTime? @default(now()) @db.Timestamp(6)              // ❌ Ngày cập nhật - thường không cần ở list

  status String? @db.VarChar(50)
  candidateExperiences Candidate_Experience[]                        // ❌ List kinh nghiệm - không show table list, để tab/detail
  schedules Schedules_Candidates[]                                   // ❌ Lịch phỏng vấn/agenda - để tab/detail
  jobCandidates Job_Candidates[]                                     // ❌ Mapping job-candidate - internal relation, để detail nếu cần
  candidateSkill CandidateSkill[]                                    // ❌ Kỹ năng - có thể hiển thị dạng tag trong detail, không nên nhét table
  reviewCandidate CandidateReview[]
  statusApplication Application[]
  auditLogs CandidateAuditLog[]
}

model CandidateAuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  candidate_id String @db.Uuid
  actor_employee_id String? @db.Uuid

  actor_type String @default("System") @db.VarChar(30)
  actor_role String? @db.VarChar(100)

  action String @db.VarChar(120)
  message String @db.Text
  metadata Json?

  created_at DateTime @default(now()) @db.Timestamp(6)

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  actorEmployee Employee? @relation(fields: [actor_employee_id], references: [id], onDelete: SetNull)

  @@index([candidate_id, created_at])
  @@index([actor_employee_id])
}

//#region APPLICATION
model Application {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  candidate_id  String   @db.Uuid
  recruitment_infor_id        String   @db.Uuid

  status        String   @db.VarChar(100)

  note          String?  @db.Text

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  candidate     Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  recruitment_infor           Recruitment_Infor       @relation(fields: [recruitment_infor_id], references: [id], onDelete: Cascade)

  @@unique([candidate_id, recruitment_infor_id])
}

//#region KINH NGHIEM LAM VIEC - HAVED
model Candidate_Experience {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidate_id String @db.Uuid
  company_name String? @db.VarChar(200)
  position String? @db.VarChar(100)
  from_month DateTime? @db.Date
  to_month DateTime? @db.Date
  job_description String? @db.Text
  is_active Boolean @default(true)
  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

//#region DANH GIA
model CandidateReview {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  candidate_id  String   @db.Uuid
  reviewer_id   String   @db.Uuid

  rating Decimal @db.Decimal(2,1)
  comment       String?  @db.Text

  is_active     Boolean  @default(true)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  Candidate     Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  Reviewer      Employee      @relation(fields: [reviewer_id], references: [id], onDelete: Cascade)

  @@index([candidate_id])
  @@index([reviewer_id])
  // nếu bạn muốn 1 người chỉ review 1 lần / 1 candidate:
  // @@unique([candidate_id, reviewer_id])
}

//#region LOAILICH - MD
model Schedules_Type{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  st_code String? @db.VarChar(50) @unique
  type_name String? @db.VarChar(100)
  description String? @db.Text
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  interviewSchedules Interview_Schedule[]
  typeSchedules_Links TypeSchedules_Link[]
}

//#region PHONGVAN TRUC TUYEN - MD
model TypeSchedules_Link {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tl_code String? @db.VarChar(50) @unique
  type_schedule_id String @db.Uuid
  exam_link String? @db.Text
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  scheduleType Schedules_Type @relation(fields: [type_schedule_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

//#region LICH PHONG VAN - MD
model Interview_Schedule {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sche_code String? @db.VarChar(50) @unique
  interview_date DateTime? @db.Timestamp(6)
  interview_location String? @db.Text
  interview_room String? @db.VarChar(100)
  time_duration Int @db.Integer // in minutes
  times DateTime? @db.Timestamp(6)
  type_schedule_id String? @db.Uuid
  evaluation_id String? @db.Uuid
  scheduleType Schedules_Type? @relation(fields: [type_schedule_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  candidates Schedules_Candidates[]
}

//#region UNGVIEN - HAVED
model Schedules_Candidates{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interview_schedule_id String @db.Uuid
  candidate_id String @db.Uuid
  interviewSchedule Interview_Schedule @relation(fields: [interview_schedule_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([interview_schedule_id, candidate_id])
}

//#region CONGVIEC - MD
model Job {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_code String? @db.VarChar(50) @unique
  name_job String? @db.VarChar(200)
  description_job String? @db.Text
  type_job String? @db.VarChar(100) // constant
  result_job String? @db.VarChar(100) // constant : FAIL; PASSED
  employee_id String? @db.Uuid // khoa ngoai - nguoi thuc hien
  deadline DateTime? @db.Date
  remind_enabled Boolean? @default(false)
  remind_before_minutes Int? @db.Integer
  status String? @db.VarChar(50)
  is_active Boolean @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  employee Employee? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  jobCandidates Job_Candidates[]
}

//#region UNGVIENCONGVIEC - HAVED
model Job_Candidates {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id String @db.Uuid
  candidate_id String @db.Uuid
  job Job @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

//#region KY NANG
model Skill{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  parent_id String?  @db.Uuid
  is_active Boolean @default(true)
  parent Skill? @relation("SkillTree", fields: [parent_id], references: [id])
  children Skill[] @relation("SkillTree")
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  positionSkill PositionSkill[]
  candidateSkill CandidateSkill[]
  @@unique([name, parent_id])
}

model PositionSkill{
  position_id String @db.Uuid
  skill_id String @db.Uuid
  level Int?
  is_required Boolean @default(true)
  position Setting_Position_Posts @relation(fields: [position_id], references: [id])
  skill Skill @relation(fields: [skill_id], references: [id])

  @@id([position_id, skill_id])
}

model CandidateSkill {
  candidate_id String @db.Uuid
  skill_id String @db.Uuid
  level Int?
  candidate Candidate @relation(fields: [candidate_id], references: [id])
  skill Skill @relation(fields: [skill_id], references: [id])

  @@id([candidate_id, skill_id])
}


//#region HỒ SƠ ĐĂNG KÝ SỬ DỤNG APP
model CompanyRegistrationRequest {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName String
  email       String
  phone       String?
  address     String?
  status      String    // pending, approved, rejected
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?
  adminNote   String?
  createdById String? @db.Uuid
  createdBy   Employee?  @relation(fields: [createdById], references: [id])
  is_active Boolean @default(true)
  inforCompanyId String?  @db.Uuid
  inforCompany   InforCompany? @relation(fields: [inforCompanyId], references: [id], onDelete: Cascade, onUpdate: Cascade )
}